generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(uuid())
  username        String   @unique
  passwordHash    String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  refreshToken    String?
  coverPictureUrl String?

  @@index([username])
}

model Product {
  id              String            @id @default(uuid())

  productName     String            @unique
  quantity        Int

  productImage    String?

  categoryId      String?
  productCategory ProductCategory?  @relation(fields: [categoryId], references: [id])

  brandId         String?
  brand           Brand?            @relation(fields: [brandId], references: [id])

  serviceTypeId   String?
  serviceType     ServiceType?      @relation(fields: [serviceTypeId], references: [id])

  variants        ProductVariant[]

  isHidden        Boolean           @default(false)

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([productName])
  @@index([isHidden])
  @@index([serviceTypeId])
}

model ProductCategory {
  id                 String            @id @default(uuid())

  categoryName       String            @unique
  categoryParentId   String?

  categoryImage      String
  categoryDesc       String

  productSubCategory ProductCategory?  @relation("CategoryHierarchy", fields: [categoryParentId], references: [id])

  subCategories      ProductCategory[] @relation("CategoryHierarchy")

  products           Product[]

  @@index([categoryName])
}

model Brand {
  id           String    @id @default(uuid())

  brandName    String    @unique
  brandImage   String?
  brandDesc    String

  products     Product[]

  @@index([brandName])
}

model ServiceType {
  id            String    @id @default(uuid())

  serviceName   String    @unique
  attributes    AttributeDefinition[]

  products      Product[]

  createdAt     DateTime  @default(now())

  @@index([serviceName])
}

model ProductVariant {
  id         String @id @default(uuid())

  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  sku        String?
  price      Decimal @db.Decimal(10,2)
  stock      Int
  cogsData   Json?

  attributes VariantAttribute[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([productId])
  @@index([sku])
}

model VariantAttribute {
  id            String @id @default(uuid())

  variantId     String
  variant       ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  attributeId   String
  attribute     AttributeDefinition @relation(fields: [attributeId], references: [id])

  value         String

  createdAt     DateTime @default(now())

  @@index([variantId])
  @@index([attributeId])
}

model AttributeDefinition {
  id            String   @id @default(uuid())

  serviceTypeId String
  serviceType   ServiceType @relation(fields: [serviceTypeId], references: [id])

  key           String   // stable identifier: "grade"
  name          String   // display name: "Grade"

  type          String   // text | enum | number
  variantAttributes VariantAttribute[]

  allowedValues String[] // ["A", "B", "Premium A"]

  isActive      Boolean  @default(true)

  createdAt     DateTime @default(now())

  @@unique([serviceTypeId, key])
  @@index([serviceTypeId])
}

model CogsField {
  id          String   @id @default(uuid())

  name        String
  key         String   @unique

  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
}