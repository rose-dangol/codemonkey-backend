model InventoryTransaction {
  id              String   @id @default(uuid())

  variantId       String
  variant         ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  type            InventoryTransactionType

  quantity        Int
  previousStock   Int
  newStock        Int

  referenceId     String?   // orderId, purchaseOrderId, etc.
  referenceType   String?   // "order", "manual_adjustment", "restock"

  note            String?

  createdBy       String?   // admin user id

  createdAt       DateTime @default(now())

  @@index([variantId])
  @@index([type])
  @@index([createdAt])
}

enum InventoryTransactionType {
  PURCHASE
  SALE
  RETURN
  ADJUSTMENT
  DAMAGE
  RESTOCK
  RESERVE
  RELEASE
}

model ProductVariant {
  id         String @id @default(uuid())

  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  sku        String?
  price      Decimal @db.Decimal(10,2)
  stock      Int
  cogsData   Json?

  attributes VariantAttribute[]
  cartItems  CartItem[] @relation("CartItemVariant")
  inventoryTransactions InventoryTransaction[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([productId])
  @@index([sku])
}

model VariantAttribute {
  id            String @id @default(uuid())

  variantId     String
  variant       ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  attributeId   String
  attribute     AttributeDefinition @relation(fields: [attributeId], references: [id])

  value         String

  createdAt     DateTime @default(now())

  @@index([variantId])
  @@index([attributeId])
}

model AttributeDefinition {
  id            String   @id @default(uuid())

  // serviceTypeId String
  // serviceType   ServiceType @relation(fields: [serviceTypeId], references: [id])

  key           String   // stable identifier: "grade"
  name          String   // display name: "Grade"

  type          String   // text | enum | number
  variantAttributes VariantAttribute[]

  allowedValues String[] // ["A", "B", "Premium A"]

  isActive      Boolean  @default(true)

  createdAt     DateTime @default(now())

  // @@unique([serviceTypeId, key])
  // @@index([serviceTypeId])
}

model CogsField {
  id          String   @id @default(uuid())

  name        String
  key         String   @unique

  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
}


